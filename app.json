{
  "expo": {
    "name": "Nexil",
    "slug": "Nexil",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "nexil",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "developmentClient": {
      "silentLaunch": true
    },
    "experiments": {
      "turboModules": true
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch",
          "processing",
          "audio"
        ],
        "BGTaskSchedulerPermittedIdentifiers": [
          "com.saisreesatya.Nexil.background-fetch",
          "com.saisreesatya.Nexil.background-task"
        ]
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.saisreesatya.Nexil",
      "permissions": [
        "BIND_NOTIFICATION_LISTENER_SERVICE",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION",
        "FOREGROUND_SERVICE_DATA_SYNC",
        "REQUEST_IGNORE_BATTERY_OPTIMIZATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "WAKE_LOCK",
        "ACCESS_BACKGROUND_LOCATION",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "VIBRATE",
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "./withAndroidNotificationListener",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Nexil to access your location for 24/7 operation.",
          "locationAlwaysPermission": "Allow Nexil to access your location in the background.",
          "locationWhenInUsePermission": "Allow Nexil to access your location.",
          "isAndroidBackgroundLocationEnabled": true,
          "isAndroidForegroundServiceEnabled": true
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow Nexil to access your camera to scan QR codes and control the flashlight."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": "Allow Nexil to access your microphone to measure sound levels."
        }
      ],
      [
        "expo-sensors",
        {
          "motionPermission": "Allow Nexil to track your steps, device orientation, and environmental data."
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow Nexil to use FaceID for security."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca8807c1-c2d7-44b1-a01c-3d6dc2760098"
      }
    }
  }
}